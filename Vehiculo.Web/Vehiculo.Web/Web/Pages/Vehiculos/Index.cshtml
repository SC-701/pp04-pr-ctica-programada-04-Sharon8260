@page
@model Web.Pages.Vehiculos.IndexModel
@{
}

<h1 class="mb-4 text-center">🚗 Listado de Vehículos</h1>

<div class="container">
    <div class="text-center mb-4">
        <a type="button" class="btn btn-success" asp-page="./Agregar">Agregar vehiculo</a>
    </div>
    

    <div class="row">
        @if (Model.vehiculos != null && Model.vehiculos.Any())
        {
            @foreach (var vehiculo in Model.vehiculos)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title text-primary">
                                @vehiculo.Marca - @vehiculo.Modelo
                            </h5>

                            <p class="card-text">
                                <strong>Placa:</strong> @vehiculo.Placa
                            </p>

                            <p class="card-text">
                                <strong>Año:</strong> @vehiculo.Anio
                            </p>

                            <a type="button" class="btn btn-primary" asp-page="./Detalle" asp-route-id="@vehiculo.Id">Detalle</a>
                            <a type="button" class="btn btn-warning" asp-page="./Editar" asp-route-id="@vehiculo.Id">Editar</a>
                            <a type="button" class="btn btn-danger" asp-page="./Eliminar" asp-route-id="@vehiculo.Id">Eliminar</a>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info text-center">
                No hay vehículos registrados 🚫
            </div>
        }
    </div>
</div>