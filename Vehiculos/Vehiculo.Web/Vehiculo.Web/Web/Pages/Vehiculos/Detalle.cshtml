@page
@model Web.Pages.Vehiculos.DetalleModel
@{
}
<h1>Detalle del Vehiculo</h1>

<div class="container">
    <div class="col-md-8">
        <div class="card">
        <div class="card-body">
        <h5 class="card-title"> @Html.DisplayFor(modelo => modelo.vehiculo.Marca) 
            @Html.DisplayFor(modelo => modelo.vehiculo.Modelo)</h5>
        <p class="card-text">
            <div>
                <div>
                    <b>
                        @Html.DisplayNameFor(modelo => modelo.vehiculo.Placa): 
                        @Html.DisplayFor(modelo => modelo.vehiculo.Placa)
                    </b>
                </div>

                <div>
                    <b>
                        @Html.DisplayNameFor(modelo => modelo.vehiculo.Anio): 
                        @Html.DisplayFor(modelo => modelo.vehiculo.Anio)
                    </b>
                </div>

                <div>
                    <b>
                        @Html.DisplayNameFor(modelo => modelo.vehiculo.Precio):
                        @Html.DisplayFor(modelo => modelo.vehiculo.Precio)
                    </b>
                </div>
                </p>
                <p class="card-text">
                    <small class="text-muted">@Html.DisplayFor(modelo => modelo.vehiculo.CorreoPropietario) | @Html.DisplayFor(modelo => modelo.vehiculo.TelefonoPropietario)</small>
                </p>
            </div>
        
        </div>
    </div>
    </div>
    <a type="button" class="btn btn-primary" asp-page="./Index">Volver</a>
    <a type="button" class="btn btn-warning" asp-page="./Editar" asp-route-id="@Model.vehiculo.Id">Editar</a>

</div>
